              "fill": "$white",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "The Real Problem Isn't Your Prompt",
              "lineHeight": 1.2,
              "fontFamily": "Inter",
              "fontSize": 24,
              "fontWeight": "700",
              "letterSpacing": -0.3
            },
            {
              "type": "frame",
