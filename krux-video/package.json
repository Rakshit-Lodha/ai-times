{
  "name": "krux-video",
  "version": "1.0.0",
  "scripts": {
    "preview": "remotion preview src/index.ts",
    "render:vertical": "remotion render src/index.ts KruxVertical out/krux-vertical.mp4 --codec=h264",
    "render:horizontal": "remotion render src/index.ts KruxHorizontal out/krux-horizontal.mp4 --codec=h264",
    "render:hq": "remotion render src/index.ts KruxVertical out/krux-vertical-hq.mp4 --codec=h264 --crf=18",
    "render:all": "npm run render:vertical && npm run render:horizontal",
    "generate-vo": "npx tsx scripts/generate-vo.ts"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.429",
    "@remotion/cli": "^4.0.429",
    "@types/react": "^19.2.14",
    "dotenv": "^16.4.0",
    "openai": "^4.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.429",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "zod": "4.3.6"
  }
}
